@model List<CartItemViewModel>
@{
    ViewData["Title"] = "Shopping Cart";
    var subtotal = Model.Sum(x => x.Price * x.Quantity);
    var discount = 0m;
    var shipping = 0m;
    var tax = Math.Round(subtotal * 0.23m, 2);
    var total = subtotal - discount + shipping + tax;
}

<link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />

<div class="cart-page">
    <div class="container">
        <div class="cart-layout">
            <!-- Shopping Cart -->
            <div class="shopping-cart">
                <div class="shopping-cart-header">
                    <h2>Shopping Cart</h2>
                </div>
                
                @if (Model.Any())
                {
                    <div class="cart-table">
                        <div class="cart-table-header">
                            <span>Products</span>
                            <span>Price</span>
                            <span>Quantity</span>
                            <span>Sub-Total</span>
                            <span></span>
                        </div>
                        
                        @foreach (var item in Model)
                        {
                            <div class="cart-item" data-id="@item.CartItemId" data-price="@item.Price">
                                <div class="cart-product-info">
                                    <form asp-action="RemoveFromCart" asp-controller="Cart" method="post" class="remove-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="cart-product-remove" title="Remove item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                        </button>
                                    </form>
                                    <img src="@item.ImageUrl" alt="@item.Name" class="cart-product-image" />
                                    <span class="cart-product-name">@item.Name</span>
                                </div>
                                
                                <div class="cart-price">
                                    @if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                                    {
                                        <span class="cart-price-original">@item.OriginalPrice.Value.ToString("C0")</span>
                                    }
                                    <span class="cart-price-current">@item.Price.ToString("C0")</span>
                                </div>
                                
                                <div class="cart-quantity">
                                    <button class="qty-minus">−</button>
                                    <input type="number" value="@item.Quantity" min="1" class="qty-input" />
                                    <button class="qty-plus">+</button>
                                </div>
                                
                                <div class="cart-subtotal">
                                    <span class="subtotal-value">@((item.Price * item.Quantity).ToString("C0"))</span>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <div class="cart-actions">
                        <a href="/Products" class="btn-return-shop">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Return to shop
                        </a>
                        <button class="btn-update-cart">Update Cart</button>
                    </div>
                }
                else
                {
                    <div class="cart-empty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        <h3>Your cart is empty</h3>
                        <p>Looks like you haven't added any products to your cart yet.</p>
                        <a href="/Products" class="btn-return-shop">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Start Shopping
                        </a>
                    </div>
                }
            </div>
            
            <!-- Sidebar -->
            <div class="cart-sidebar">
                <!-- Card Totals -->
                <div class="card-totals">
                    <h3>Card Totals</h3>
                    
                    <div class="totals-row">
                        <span>Sub-total</span>
                        <span id="cart-subtotal">@subtotal.ToString("C0")</span>
                    </div>
                    
                    <div class="totals-row">
                        <span>Shipping</span>
                        <span id="cart-shipping">@(shipping == 0 ? "Free" : shipping.ToString("C0"))</span>
                    </div>
                    
                    <div class="totals-row">
                        <span>Discount</span>
                        <span id="cart-discount">@discount.ToString("C0")</span>
                    </div>
                    
                    <div class="totals-row">
                        <span>Tax</span>
                        <span id="cart-tax">@tax.ToString("C0")</span>
                    </div>
                    
                    <div class="totals-row total">
                        <span>Total</span>
                        <span id="cart-total">@total.ToString("C0") USD</span>
                    </div>
                    
                    <button class="btn-checkout">
                        Proceed to checkout
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>
                
                <!-- Coupon Code -->
                <div class="coupon-card">
                    <h3>Coupon Code</h3>
                    <div class="coupon-input-group">
                        <input type="text" placeholder="Email address" id="coupon-input" />
                        <button class="btn-apply-coupon">Apply Coupon</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    const taxRate = 0.23;
    
    function recalculateTotals() {
        let subtotal = 0;
        document.querySelectorAll('.cart-item').forEach(item => {
            const price = parseFloat(item.dataset.price);
            const qty = parseInt(item.querySelector('.qty-input').value);
            subtotal += price * qty;
            
            // Update row subtotal
            item.querySelector('.subtotal-value').textContent = '$' + (price * qty).toFixed(0);
        });
        
        const tax = subtotal * taxRate;
        const total = subtotal + tax;
        
        document.getElementById('cart-subtotal').textContent = '$' + subtotal.toFixed(0);
        document.getElementById('cart-tax').textContent = '$' + tax.toFixed(0);
        document.getElementById('cart-total').textContent = '$' + total.toFixed(2) + ' USD';
    }
    
    // Quantity buttons
    document.querySelectorAll('.cart-item').forEach(item => {
        const qtyInput = item.querySelector('.qty-input');
        const minusBtn = item.querySelector('.qty-minus');
        const plusBtn = item.querySelector('.qty-plus');
        
        minusBtn.addEventListener('click', () => {
            let qty = parseInt(qtyInput.value);
            if (qty > 1) {
                qtyInput.value = qty - 1;
                recalculateTotals();
            }
        });
        
        plusBtn.addEventListener('click', () => {
            let qty = parseInt(qtyInput.value);
            qtyInput.value = qty + 1;
            recalculateTotals();
        });
        
        qtyInput.addEventListener('change', () => {
            if (parseInt(qtyInput.value) < 1) {
                qtyInput.value = 1;
            }
            recalculateTotals();
        });
    });
    
    // Remove item forms - add animation before submit
    document.querySelectorAll('.remove-form').forEach(form => {
        form.addEventListener('submit', (e) => {
            const item = form.closest('.cart-item');
            item.style.opacity = '0';
            item.style.transform = 'translateX(-20px)';
            // Allow animation to play before submitting
        });
    });
});
</script>
}
