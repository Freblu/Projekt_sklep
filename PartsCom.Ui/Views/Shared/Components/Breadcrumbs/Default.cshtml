@using PartsCom.Ui.ViewComponents
@model List<BreadcrumbItem>

@if (Model != null && Model.Count > 0)
{
    var filteredItems = Model.Where(m => !string.IsNullOrEmpty(m.Text)).ToList();
    <div class="breadcrumbs-section">
        <div class="container">
             <nav aria-label="breadcrumb">
                <ol class="breadcrumb-list">
                    @for (int i = 0; i < filteredItems.Count; i++)
                    {
                        var item = filteredItems[i];
                        bool isLast = i == filteredItems.Count - 1;
                        <li class="breadcrumb-list-item @(isLast ? "active" : "")">
                            @if (isLast)
                            {
                                <span class="current-page">@item.Text</span>
                            }
                            else
                            {
                                <a href="@item.Path" class="breadcrumb-link">
                                    @if (item.Text == "Home")
                                    {
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="home-icon">
                                            <path d="M3 9.5L12 2L21 9.5V21C21 21.5523 20.5523 22 20 22H15V16H9V22H4C3.44772 22 3 21.5523 3 21V9.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        <span class="ms-1">@item.Text</span>
                                    }
                                    else
                                    {
                                        @item.Text
                                    }
                                </a>
                                <span class="separator">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M9 18L15 12L9 6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </span>
                            }
                        </li>
                    }
                </ol>
            </nav>
        </div>
    </div>
}
