@using PartsCom.Application.Queries.GetHomePage
@model GetHomePageQueryResponse
@{
    ViewData["Title"] = "Strona Główna";
}

@* --- DYNAMIC DATA SECTION --- *@
<section class="container mt-4">
    <div class="row g-4">
        @* Main Hero Banner *@
        <div class="col-lg-8">
            <div class="p-5 bg-light rounded shadow-sm h-100 d-flex align-items-center justify-content-between position-relative overflow-hidden">
                @if (Model.HeroProduct != null)
                {
                    <div class="z-1" style="max-width: 60%;">
                        <h6 class="text-primary mb-2">Polecamy</h6>
                        <h2 class="fw-bold mb-3">@Model.HeroProduct.Name</h2>
                        <p class="mb-4 text-truncate" style="max-height: 3em;">@Model.HeroProduct.Description</p>
                        <a href="/Products/Details/@Model.HeroProduct.Id" class="btn btn-warning px-4 py-2">Sprawdź ofertę</a>
                    </div>
                    <div class="position-relative" style="width: 300px; height: 300px;">
                         <img src="@(Model.HeroProduct.MainImageUrl ?? "https://via.placeholder.com/300")" 
                              class="img-fluid position-absolute top-50 start-50 translate-middle" 
                              style="max-height: 100%; max-width: 100%; object-fit: contain;" 
                              alt="@Model.HeroProduct.Name" />
                    </div>
                }
                else
                {
                    <div class="text-center w-100">Brak produktów w bazie.</div>
                }
            </div>
        </div>

        @* Side Banners *@
        <div class="col-lg-4 d-flex flex-column gap-4">
            @if (Model.PromoProduct1 != null)
            {
                <div class="p-4 bg-light rounded shadow-sm d-flex justify-content-between align-items-center h-50">
                    <div style="width: 60%;">
                        <h6 class="text-warning mb-1">Hit cenowy</h6>
                        <h5 class="mb-2 text-truncate" title="@Model.PromoProduct1.Name">@Model.PromoProduct1.Name</h5>
                        <p class="text-primary fw-bold mb-2">@Model.PromoProduct1.Price.ToString("C")</p>
                    </div>
                    <div style="width: 35%; height: 100px; display: flex; align-items: center; justify-content: center;">
                        <img src="@(Model.PromoProduct1.MainImageUrl ?? "https://via.placeholder.com/100")" 
                             style="max-height: 100%; max-width: 100%; object-fit: contain;" 
                             alt="@Model.PromoProduct1.Name" />
                    </div>
                </div>
            }
            
            @if (Model.PromoProduct2 != null)
            {
                <div class="p-4 bg-light rounded shadow-sm d-flex justify-content-between align-items-center h-50">
                    <div style="width: 60%;">
                        <h6 class="text-muted mb-1">Nowość</h6>
                        <h5 class="mb-2 text-truncate" title="@Model.PromoProduct2.Name">@Model.PromoProduct2.Name</h5>
                        <a href="/Products/Details/@Model.PromoProduct2.Id" class="btn btn-outline-primary btn-sm">Zobacz</a>
                    </div>
                     <div style="width: 35%; height: 100px; display: flex; align-items: center; justify-content: center;">
                        <img src="@(Model.PromoProduct2.MainImageUrl ?? "https://via.placeholder.com/100")" 
                             style="max-height: 100%; max-width: 100%; object-fit: contain;" 
                             alt="@Model.PromoProduct2.Name" />
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* Features Section *@
<section class="container my-5">
    <div class="row text-center">
        <div class="col-md-3">
            <div class="p-3 border rounded h-100">
                <i class="bi bi-box-seam fs-2 text-primary mb-2"></i>
                <h6 class="fw-bold mt-2">Szybka dostawa</h6>
                <small class="text-muted">Dostawa w 24h</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 border rounded h-100">
                <i class="bi bi-shield-check fs-2 text-primary mb-2"></i>
                <h6 class="fw-bold mt-2">Gwarancja jakości</h6>
                <small class="text-muted">24 miesiące gwarancji</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 border rounded h-100">
                <i class="bi bi-headset fs-2 text-primary mb-2"></i>
                <h6 class="fw-bold mt-2">Wsparcie 24/7</h6>
                <small class="text-muted">Pomoc techniczna</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 border rounded h-100">
                <i class="bi bi-credit-card fs-2 text-primary mb-2"></i>
                <h6 class="fw-bold mt-2">Bezpieczne płatności</h6>
                <small class="text-muted">Szyfrowane transakcje</small>
            </div>
        </div>
    </div>
</section>

@* Featured Products Grid *@
<section class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Polecane Produkty</h4>
        <a href="/products" class="text-decoration-none">Wszystkie produkty &rarr;</a>
    </div>

    <div class="row g-4">
        @foreach (var product in Model.FeaturedProducts)
        {
            <div class="col-md-3 col-sm-6">
                <div class="card h-100 shadow-sm border-0">
                    <div class="position-relative p-3" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                        <img src="@(product.MainImageUrl ?? "https://via.placeholder.com/300x200?text=No+Image")" 
                             class="img-fluid" 
                             style="max-height: 100%; max-width: 100%; object-fit: contain;" 
                             alt="@product.Name">
                    </div>
                    <div class="card-body d-flex flex-column bg-white">
                        <div class="mb-2">
                             @if(!string.IsNullOrEmpty(product.CategoryName)) {
                                 <span class="badge bg-light text-secondary border">@product.CategoryName</span>
                             }
                        </div>
                        <h6 class="card-title text-truncate" title="@product.Name">
                            <a href="/Products/Details/@product.Id" class="text-dark text-decoration-none">@product.Name</a>
                        </h6>
                        <div class="mt-auto pt-2 border-top">
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="text-primary fw-bold fs-5">@product.Price.ToString("C")</span>
                                <form asp-action="AddToCart" asp-controller="Cart" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm" title="Dodaj do koszyka">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart" viewBox="0 0 16 16">
                                          <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>


@* Categories Carousel *@
@if (Model.Categories.Any())
{
    <div class="container my-4">
      <section class="container-fluid my-5">
        <h4 class="fw-bold mb-3">Kategorie</h4>
        <div id="categoriesCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            @for (int i = 0; i < Math.Ceiling(Model.Categories.Count / 6.0); i++)
            {
                <div class="carousel-item @(i == 0 ? "active" : "")">
                  <div class="d-flex justify-content-center gap-4 flex-wrap">
                    @foreach (var category in Model.Categories.Skip(i * 6).Take(6))
                    {
                        <div class="text-center">
                          <a href="/products?categoryId=@category.Id" class="text-decoration-none text-dark">
                              <div class="bg-light p-3 rounded-circle mb-2 d-flex align-items-center justify-content-center hover-shadow transition" style="width:80px; height:80px;">
                                  <i class="bi bi-cpu fs-2 text-secondary"></i> 
                                  @* Ideally icon would be from DB *@
                              </div>
                              <small>@category.Name</small>
                          </a>
                        </div>
                    }
                  </div>
                </div>
            }
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#categoriesCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon bg-secondary rounded-circle" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#categoriesCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon bg-secondary rounded-circle" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </section>
      
      @* Promo Banners *@
      <div class="row my-4">
        <div class="col-md-4 mb-3">
          <div class="bg-warning p-3 rounded text-dark h-100">
            <h5 class="mb-2">Wyprzedaż Sezonowa</h5>
            <p>Nie przegap okazji na najlepszy sprzęt w najniższych cenach.</p>
            <p>Raty 0% na wszystko!</p>
            <a class="btn btn-dark" href="/products">Sprawdź Promocje</a>
          </div>
        </div>
        @* Dynamic Promo Products *@
        @if (Model.Bestsellers.Count >= 1) {
            var p = Model.Bestsellers[0];
            <div class="col-md-4 mb-3">
              <div class="bg-light p-3 rounded d-flex align-items-center justify-content-between h-100">
                <div>
                  <h5 class="text-truncate" style="max-width: 150px;">@p.Name</h5>
                  <a class="btn btn-outline-primary mt-2" href="/Products/Details/@p.Id">Kup Teraz</a>
                </div>
                <img src="@(p.MainImageUrl ?? "https://via.placeholder.com/100")" style="max-height: 100px; max-width: 100px; object-fit: contain;" alt="@p.Name" />
              </div>
            </div>
        }
        @if (Model.Bestsellers.Count >= 2) {
             var p = Model.Bestsellers[1];
            <div class="col-md-4 mb-3">
              <div class="bg-light p-3 rounded d-flex align-items-center justify-content-between h-100">
                <div>
                  <h5 class="text-truncate" style="max-width: 150px;">@p.Name</h5>
                  <p class="text-primary fw-bold">@p.Price.ToString("C")</p>
                  <a class="btn btn-primary" href="/Products/Details/@p.Id">Kup</a>
                </div>
                <img src="@(p.MainImageUrl ?? "https://via.placeholder.com/100")" style="max-height: 100px; max-width: 100px; object-fit: contain;" alt="@p.Name" />
              </div>
            </div>
        }
      </div>

      @* Specific Category: Karty Graficzne *@
      @if (Model.SpecificCategoryProducts.Any())
      {
          <h3 class="mb-3">Karty Graficzne i Podzespoły</h3>
          <div class="row mb-4">
            @foreach (var product in Model.SpecificCategoryProducts) { 
                <div class="col-md-3 mb-4">
                  <div class="card h-100 shadow-sm border-0">
                    <div class="bg-white p-3 d-flex align-items-center justify-content-center" style="height:150px;">
                        <img src="@(product.MainImageUrl ?? "https://via.placeholder.com/150")" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@product.Name" />
                    </div>
                    <div class="card-body d-flex flex-column">
                      <h6 class="card-title mb-2 text-truncate" title="@product.Name">@product.Name</h6>
                      <p class="text-primary fw-bold mb-2">@product.Price.ToString("C")</p>
                      <a href="/Products/Details/@product.Id" class="btn btn-outline-dark mt-auto">Zobacz</a>
                    </div>
                  </div>
                </div>
            }
          </div>
      }

      @* Single Feature Product *@
      @if (Model.SpecificFeatureProduct != null)
      {
          <div class="bg-light p-4 rounded mb-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Produkt Premium</h4>
                <a href="/Products/Details/@Model.SpecificFeatureProduct.Id">Zobacz szczegóły</a>
              </div>
              <div class="row align-items-center">
                <div class="col-md-6 mb-3 text-center">
                  <img src="@(Model.SpecificFeatureProduct.MainImageUrl ?? "https://via.placeholder.com/400x250")" class="img-fluid rounded" style="max-height: 250px; object-fit: contain;" alt="@Model.SpecificFeatureProduct.Name" />
                </div>
                <div class="col-md-6">
                  <h4>@Model.SpecificFeatureProduct.Name</h4>
                  <h5 class="text-primary fw-bold mb-3">@Model.SpecificFeatureProduct.Price.ToString("C")</h5>
                  <p>@Model.SpecificFeatureProduct.Description</p>
                  <a href="/Products/Details/@Model.SpecificFeatureProduct.Id" class="btn btn-primary btn-lg">Kup Teraz</a>
                </div>
              </div>
          </div>
      }

      @* News Section *@
      @if (Model.News.Any())
      {
          <section class="container my-5">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold">Aktualności</h4>
                <a href="#" class="text-decoration-none">Wszystkie wpisy &rarr;</a>
              </div>
              <div class="row g-4">
                @foreach (var news in Model.News) { 
                    <div class="col-md-4">
                      <div class="card h-100 shadow-sm border-0">
                        <img src="@(news.ImageUrl ?? "https://via.placeholder.com/400x250")" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@news.Title">
                        <div class="card-body">
                          <h5 class="card-title text-truncate">@news.Title</h5>
                          <p class="card-text small text-muted" style="height: 4.5em; overflow: hidden;">@news.ShortDescription</p>
                          <p class="text-muted small mb-2">@news.PublishedAt</p>
                          <a href="#" class="btn btn-outline-dark w-100">Czytaj Dalej</a>
                        </div>
                      </div>
                    </div>
                }
              </div>
          </section>
      }
    </div>
}