@model AddressViewModel
@{
    ViewData["Title"] = "Edit Address";
}
<link rel="stylesheet" href="~/style/dashboard/dashboard.css" asp-append-version="true" />

<div class="container-fluid p-0 dashboard-container">
    <div class="row">
        <!-- ASIDE -->
        <aside class="col-12 col-lg-3">
            <nav class="db-aside">
                <a class="db-aside__link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Index">Order History</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Track">Track Order</a>
                <a class="db-aside__link" asp-controller="Cart" asp-action="Index">Shopping Cart</a>
                <a class="db-aside__link" asp-controller="Wishlist" asp-action="Index">Wishlist</a>
                <a class="db-aside__link" asp-controller="Compare" asp-action="Index">Compare</a>
                <a class="db-aside__link db-aside__link--active" asp-controller="Settings" asp-action="Addresses">Cards & Address</a>
                <a class="db-aside__link" asp-controller="Browsing" asp-action="History">Browsing History</a>
                <a class="db-aside__link" asp-controller="Settings" asp-action="Index">Setting</a>
                <a class="db-aside__link" asp-controller="Auth" asp-action="Logout">Log-out</a>
            </nav>
        </aside>

        <!-- MAIN -->
        <main class="col-12 col-lg-9">
            <header class="db-header">
                <h3 class="db-title">Edit Address</h3>
                <p class="db-subtitle">Update your address information below.</p>
            </header>

            <div class="db-card">
                <form asp-action="EditAddress" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Type" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AddressLine1" class="form-label"></label>
                        <input asp-for="AddressLine1" class="form-control" />
                        <span asp-validation-for="AddressLine1" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AddressLine2" class="form-label"></label>
                        <input asp-for="AddressLine2" class="form-control" placeholder="(optional)" />
                        <span asp-validation-for="AddressLine2" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="PostalCode" class="form-label"></label>
                                <input asp-for="PostalCode" class="form-control" />
                                <span asp-validation-for="PostalCode" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="City" class="form-label"></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Country" class="form-label"></label>
                        <input asp-for="Country" class="form-control" />
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                        <label asp-for="IsDefault" class="form-check-label">Set as default address</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="db-btn db-btn--primary">Save Changes</button>
                        <a asp-action="Addresses" class="db-btn db-btn--outline">Cancel</a>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>
