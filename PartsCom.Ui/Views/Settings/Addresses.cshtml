@model List<AddressViewModel>
@{
    ViewData["Title"] = "Addresses";
}
<link rel="stylesheet" href="~/style/dashboard/dashboard.css" asp-append-version="true" />

<div class="container-fluid p-0 dashboard-container">
    <div class="row">
        <!-- ASIDE -->
        <aside class="col-12 col-lg-3">
            <nav class="db-aside">
                <a class="db-aside__link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Index">Order History</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Track">Track Order</a>
                <a class="db-aside__link" asp-controller="Cart" asp-action="Index">Shopping Cart</a>
                <a class="db-aside__link" asp-controller="Wishlist" asp-action="Index">Wishlist</a>
                <a class="db-aside__link" asp-controller="Compare" asp-action="Index">Compare</a>
                <a class="db-aside__link db-aside__link--active" asp-controller="Settings" asp-action="Addresses">Cards & Address</a>
                <a class="db-aside__link" asp-controller="Browsing" asp-action="History">Browsing History</a>
                <a class="db-aside__link" asp-controller="Settings" asp-action="Index">Setting</a>
                <a class="db-aside__link" asp-controller="Auth" asp-action="Logout">Log-out</a>
            </nav>
        </aside>

        <!-- MAIN -->
        <main class="col-12 col-lg-9">
            <header class="db-header">
                <h3 class="db-title">My Addresses</h3>
                <p class="db-subtitle">Manage your shipping and billing addresses.</p>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="db-section">
                <div class="db-section__head">
                    <h5 class="db-h5">Saved Addresses</h5>
                    <a asp-action="AddAddress" class="db-link">Add New Address +</a>
                </div>

                @if (Model.Count == 0)
                {
                    <div class="db-card">
                        <p class="text-muted mb-0">You have no saved addresses. Click "Add New Address" to add one.</p>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var address in Model)
                        {
                            <div class="col-12 col-md-6">
                                <div class="db-card">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="db-fw">@address.FullName</div>
                                            @if (address.IsDefault)
                                            {
                                                <span class="badge bg-primary">Default</span>
                                            }
                                            <span class="badge bg-secondary">@address.Type</span>
                                        </div>
                                    </div>
                                    <div class="db-muted">@address.AddressLine1</div>
                                    @if (!string.IsNullOrEmpty(address.AddressLine2))
                                    {
                                        <div class="db-muted">@address.AddressLine2</div>
                                    }
                                    <div class="db-muted">@address.PostalCode @address.City</div>
                                    <div class="db-muted">@address.Country</div>
                                    <div class="db-muted"><strong>Phone:</strong> @address.PhoneNumber</div>

                                    <div class="db-actions mt-3">
                                        <a asp-action="EditAddress" asp-route-id="@address.Id" class="db-btn db-btn--outline btn-sm">Edit</a>
                                        <form asp-action="DeleteAddress" asp-route-id="@address.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="db-btn db-btn--outline btn-sm text-danger">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
</div>
