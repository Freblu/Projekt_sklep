@model EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}
<link rel="stylesheet" href="~/style/dashboard/dashboard.css" asp-append-version="true" />

<div class="container-fluid p-0 dashboard-container">
    <div class="row">
        <!-- ASIDE -->
        <aside class="col-12 col-lg-3">
            <nav class="db-aside">
                <a class="db-aside__link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Index">Order History</a>
                <a class="db-aside__link" asp-controller="Orders" asp-action="Track">Track Order</a>
                <a class="db-aside__link" asp-controller="Cart" asp-action="Index">Shopping Cart</a>
                <a class="db-aside__link" asp-controller="Wishlist" asp-action="Index">Wishlist</a>
                <a class="db-aside__link" asp-controller="Compare" asp-action="Index">Compare</a>
                <a class="db-aside__link" asp-controller="Settings" asp-action="Addresses">Cards & Address</a>
                <a class="db-aside__link" asp-controller="Browsing" asp-action="History">Browsing History</a>
                <a class="db-aside__link db-aside__link--active" asp-controller="Settings" asp-action="Index">Setting</a>
                <a class="db-aside__link" asp-controller="Auth" asp-action="Logout">Log-out</a>
            </nav>
        </aside>

        <!-- MAIN -->
        <main class="col-12 col-lg-9">
            <header class="db-header">
                <h3 class="db-title">Edit Profile</h3>
                <p class="db-subtitle">Update your personal information below.</p>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="db-card">
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" readonly disabled />
                        <small class="text-muted">Email cannot be changed.</small>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+48 123 456 789" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="City" class="form-label"></label>
                                <input asp-for="City" class="form-control" placeholder="e.g. Warszawa" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AvatarUrl" class="form-label"></label>
                        <input asp-for="AvatarUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="db-btn db-btn--primary">Save Changes</button>
                        <a asp-controller="Dashboard" asp-action="Index" class="db-btn db-btn--outline">Cancel</a>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>
